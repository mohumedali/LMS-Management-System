@using CourseManagment.BLL.ViewModels.ProfileVM
@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="~/css/navbar.css">
    <link rel="stylesheet" href="~/css/register.css">
    <link rel="stylesheet" href="~/css/footer.css">

    <link rel="icon" type="image/png" href="~/img/finallooogggggooo.png">
    <title>Learnio</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;800&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Responsive overrides - keep last so it can override the styles above -->
    <link rel="stylesheet" href="~/css/responsive.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg bg-white shadow-sm sticky-top py-3">
        <div class="container">
            <a class="navbar-brand fw-bold fs-1 " href="~/index.html">Learnio</a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav ms-3">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-semibold" href="#" data-bs-toggle="dropdown">Categories</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="#">Development</a></li>
                            <li><a class="dropdown-item" href="#">IT & Software</a></li>
                            <li><a class="dropdown-item" href="#">UI / UX Design</a></li>
                            <li><a class="dropdown-item" href="#">Data Science</a></li>
                            <li><a class="dropdown-item" href="#">Artificial Intelligence</a></li>
                            <li><a class="dropdown-item" href="#">Business</a></li>
                            <li><a class="dropdown-item" href="#">Software Testing</a></li>
                            <li><a class="dropdown-item" href="#">Personal Development</a></li>
                        </ul>
                    </li>
                </ul>

                <form class="d-flex flex-grow-1 mx-lg-4 my-3 my-lg-0">
                    <div class="input-group">
                        <input type="text" class="form-control rounded-start-pill border-end-0" placeholder="What do you want to learn?">
                        <button class="btn btn-success rounded-end-pill px-4"><i class="fa-solid fa-magnifying-glass"></i></button>
                    </div>
                </form>

                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Course" asp-action="Index">Courses</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Enrollment" asp-action="MyLearning">My Coursers</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Profile" asp-action="Index">Profile</a>
                    </li>


                </ul>
                <div class="d-flex align-items-center ms-lg-3">
                    <a asp-controller="Account" asp-action="Login" class="nav-link fw-semibold me-3">
                        <i class="fa-solid fa-right-to-bracket"></i> Login
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="btn register-btn rounded-3 px-4">
                        <i class="fa-regular fa-user me-1"></i> Register
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <section class="page-header">
        <div class="overlay"></div>
        <div class="container">
            <div class="page-header-content">
                <h1>Sign Up</h1>
                <div class="breadcrumb">
                    <a asp-controller="Home" asp-action="Index">Home</a>
                    <span><i class="fa-solid fa-chevron-right"></i></span>
                    <a asp-controller="Course" asp-action="Index">Pages</a>
                    <span><i class="fa-solid fa-chevron-right"></i></span>
                    <span>Sign Up</span>
                </div>
            </div>
        </div>
    </section>

    <section class="register-page">
        <div class="register-box">
            <h2>Create an Account and <br> Start Learning!</h2>
            <hr>

            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger"></div>
            }

            <form asp-controller="Account" asp-action="Register" method="post">
                @Html.AntiForgeryToken()

                <label>Full Name</label>
                <div class="input-group">
                    <div class="input-box">
                        <i class="fa-regular fa-user"></i>
                        <input asp-for="FullName" type="text" placeholder="Full name">
                    </div>
                </div>
                <span asp-validation-for="FullName" class="text-danger"></span>

                <label>Email</label>
                <div class="input-group">
                    <div class="input-box">
                        <i class="fa-regular fa-envelope"></i>
                        <input asp-for="Email" type="email" placeholder="Enter email address">
                    </div>
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>

                <label>Phone</label>
                <div class="input-group">
                    <div class="input-box">
                        <i class="fa-solid fa-phone"></i>
                        <input asp-for="Phone" type="text" placeholder="Phone (optional)">
                    </div>
                </div>
                <span asp-validation-for="Phone" class="text-danger"></span>

                <label>Password</label>
                <div class="input-group">
                    <div class="input-box">
                        <i class="fa-solid fa-lock"></i>
                        <input asp-for="Password" type="password" id="password" placeholder="Password">
                        <span class="toggle-password">
                            <i class="fa-regular fa-eye"></i>
                        </span>
                    </div>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>

                <label>Confirm Password</label>
                <div class="input-group">
                    <div class="input-box">
                        <i class="fa-solid fa-lock"></i>
                        <input asp-for="ConfirmPassword" type="password" placeholder="Password" id="confirmPassword">
                        <span class="toggle-password">
                            <i class="fa-regular fa-eye"></i>
                        </span>
                    </div>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>

                <label>Register as</label>
                <div class="input-group account-type-group" style="display:flex; gap:20px; margin-bottom:15px;">
                    <label style="display:flex; align-items:center; gap:6px; font-weight:normal;">
                        <input type="radio" asp-for="AccountType" value="@RegisterAccountType.Student"
                               checked="@(Model.AccountType == RegisterAccountType.Student)"
                               onclick="toggleInstructorFields(false)">
                        Student
                    </label>
                    <label style="display:flex; align-items:center; gap:6px; font-weight:normal;">
                        <input type="radio" asp-for="AccountType" value="@RegisterAccountType.Instructor"
                               checked="@(Model.AccountType == RegisterAccountType.Instructor)"
                               onclick="toggleInstructorFields(true)">
                        Instructor
                    </label>
                </div>
                <span asp-validation-for="AccountType" class="text-danger"></span>

                <div id="instructorFields" style="display:@(Model.AccountType == RegisterAccountType.Instructor ? "block" : "none")">
                    <label>Specialization</label>
                    <div class="input-group">
                        <div class="input-box">
                            <i class="fa-solid fa-graduation-cap"></i>
                            <input asp-for="Specialization" type="text" placeholder="e.g. Web Development">
                        </div>
                    </div>
                    <span asp-validation-for="Specialization" class="text-danger"></span>

                    <label>Bio</label>
                    <div class="input-group">
                        <div class="input-box">
                            <i class="fa-solid fa-pen"></i>
                            <input asp-for="Bio" type="text" placeholder="Short bio (optional)">
                        </div>
                    </div>
                    <span asp-validation-for="Bio" class="text-danger"></span>
                </div>

                <div class="terms">
                    <input type="checkbox" required>
                    <p>
                        By signing I agree to the
                        <a href="#">terms and conditions</a>
                        and
                        <a href="#">privacy policy</a>
                    </p>
                </div>

                <button class="register-submit" type="submit">
                    Register Account
                    <i class="fa-solid fa-arrow-right"></i>
                </button>

                <p class="login-link">
                    Already have an account?
                    <a asp-controller="Account" asp-action="Login">Login</a>
                </p>
            </form>
        </div>
    </section>

    <div class="footer">
        <div class="footer-container">
            <div class="footer-about">
                <div class="footer-logo">
                    <img src="~/img/finallooogggggooo.png" alt="">
                    <h2>Learnio</h2>
                </div>
                <p><i class="fa-solid fa-phone"></i> +20 100 000 0000</p>
                <p><i class="fa-solid fa-envelope"></i> support@learnio.com</p>
                <p><i class="fa-solid fa-location-dot"></i> Cairo, Egypt</p>
                <h3>We are on</h3>
                <div class="social-icons">
                    <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#"><i class="fa-brands fa-twitter"></i></a>
                    <a href="#"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#"><i class="fa-brands fa-linkedin-in"></i></a>
                </div>
            </div>

            <div class="footer-links">
                <h3 class="footer-title">Company</h3>
                <ul>
                    <li><a href="#">About Us</a></li>
                    <li><a href="#">Contact Us</a></li>
                    <li><a href="#">Become an Instructor</a></li>
                    <li><a href="#">FAQs</a></li>
                </ul>
            </div>
            <div class="footer-links">
                <h3 class="footer-title">Courses</h3>
                <ul>
                    <li><a href="#">Web Development</a></li>
                    <li><a href="#">UI / UX</a></li>
                    <li><a href="#">Data Science</a></li>
                    <li><a href="#">Business</a></li>
                    <li><a href="#">Artificial Intelligence</a></li>
                </ul>
            </div>
            <div class="footer-apps">
                <h3 class="footer-title">Download App</h3>
                <p>Download our mobile app and learn on the go.</p>
                <img src="~/Images/app store.png" alt="App Store">
                <img src="~/Images/goagle play.png" alt="Google Play">
            </div>
        </div>
        <hr>
        <div class="footer-bottom">
            <p>© 2026 Learnio. All Rights Reserved.</p>
            <div class="bottom-links">
                <a href="#">Terms & Conditions</a>
                <a href="#">Privacy Policy</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/register.js"></script>
    <script>
        function toggleInstructorFields(show) {
        document.getElementById('instructorFields').style.display = show ? 'block' : 'none';


        }
    </script>
</body>
</html>
