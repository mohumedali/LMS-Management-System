@using CourseManagment.BLL.ViewModels.ProfileVM
@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" type="image/png" href="~/img/finallooogggggooo.png">
    <title>Learnio</title>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
    <link rel="stylesheet" href="~/css/login.css">
    <link rel="stylesheet" href="~/css/navbar.css">
    <link rel="stylesheet" href="~/css/footer.css">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
    <link rel="stylesheet" href="~/css/responsive.css">
</head>

<body>
    <nav class="navbar navbar-expand-lg bg-white shadow-sm sticky-top py-3">
        <div class="container">
            <a class="navbar-brand fw-bold fs-1 " asp-controller="Home" asp-action="Index">
                Learnio
            </a>

            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <ul class="navbar-nav ms-3">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle fw-semibold" href="#" data-bs-toggle="dropdown">Categories</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" href="#">Development</a></li>
                            <li><a class="dropdown-item" href="#">IT & Software</a></li>
                            <li><a class="dropdown-item" href="#">UI / UX Design</a></li>
                            <li><a class="dropdown-item" href="#">Data Science</a></li>
                            <li><a class="dropdown-item" href="#">Artificial Intelligence</a></li>
                            <li><a class="dropdown-item" href="#">Business</a></li>
                            <li><a class="dropdown-item" href="#">Software Testing</a></li>
                            <li><a class="dropdown-item" href="#">Personal Development</a></li>
                        </ul>
                    </li>
                </ul>

                <form class="d-flex flex-grow-1 mx-lg-4 my-3 my-lg-0">
                    <div class="input-group">
                        <input type="text" class="form-control rounded-start-pill border-end-0" placeholder="What do you want to learn?">
                        <button class="btn btn-success rounded-end-pill px-4"><i class="fa-solid fa-magnifying-glass"></i></button>
                    </div>
                </form>
                <ul class="navbar-nav">

                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Course" asp-action="Index">Courses</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Enrollment" asp-action="MyLearning">My Coursers</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Profile" asp-action="Index">Profile</a>
                    </li>


                </ul>

                <div class="d-flex align-items-center ms-lg-3">
                    <a asp-controller="Account" asp-action="Login" class="nav-link fw-semibold me-3">
                        <i class="fa-solid fa-right-to-bracket"></i> Login
                    </a>
                    <a asp-controller="Account" asp-action="Register" class="btn register-btn rounded-3 px-4">
                        <i class="fa-regular fa-user me-1"></i> Register
                    </a>
                </div>
            </div>
        </div>
    </nav>

    <section class="page-header">
        <div class="overlay"></div>
        <div class="container">
            <div class="page-header-content">
                <h1>Login</h1>
                <div class="breadcrumb">
                    <a href="~/index.html">Home</a>
                    <span><i class="fa-solid fa-chevron-right"></i></span>
                    <a href="#">Pages</a>
                    <span><i class="fa-solid fa-chevron-right"></i></span>
                    <span>Login</span>
                </div>
            </div>
        </div>
    </section>

    <section class="register-page">
        <div class="register-box">
            <h2>Login to Your Account!</h2>
            <hr>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success">@TempData["SuccessMessage"]</div>
            }
            @if (!ViewData.ModelState.IsValid)
            {
                <div asp-validation-summary="All" class="alert alert-danger"></div>
            }

            <form asp-controller="Account" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <label>Email</label>
                <div class="input-group">
                    <div class="input-box">
                        <i class="fa-regular fa-user"></i>
                        <input asp-for="Email" type="text" placeholder="Enter your email">
                    </div>
                </div>
                <span asp-validation-for="Email" class="text-danger"></span>

                <label>Password</label>
                <div class="input-group">
                    <div class="input-box">
                        <i class="fa-solid fa-lock"></i>
                        <input asp-for="Password" type="password" id="password" placeholder="Password">
                        <span class="toggle-password">
                            <i class="fa-regular fa-eye"></i>
                        </span>
                    </div>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>

                <div class="terms">
                    <input asp-for="RememberMe" type="checkbox">
                    <p>
                        Remember Me
                        <a asp-controller="Account" asp-action="ForgetPassword">Forgot my password?</a>
                    </p>
                </div>

                <button class="register-submit" type="submit">
                    Login Account
                    <i class="fa-solid fa-arrow-right"></i>
                </button>

                <p class="login-link">
                    Don't have an account?
                    <a asp-controller="Account" asp-action="Register">Register</a>
                </p>
            </form>
        </div>
    </section>

    <div class="footer">
        <div class="footer-container">
            <div class="footer-about">
                <div class="footer-logo">
                    <img src="~/img/finallooogggggooo.png" alt="">
                    <h2>Learnio</h2>
                </div>
                <p><i class="fa-solid fa-phone"></i> +20 100 000 0000</p>
                <p><i class="fa-solid fa-envelope"></i> support@learnio.com</p>
                <p><i class="fa-solid fa-location-dot"></i> Cairo, Egypt</p>
                <h3>We are on</h3>
                <div class="social-icons">
                    <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                    <a href="#"><i class="fa-brands fa-twitter"></i></a>
                    <a href="#"><i class="fa-brands fa-instagram"></i></a>
                    <a href="#"><i class="fa-brands fa-linkedin-in"></i></a>
                </div>
            </div>

            <div class="footer-links">
                <h3 class="footer-title">Company</h3>
                <ul>
                    <li><a href="#">About Us</a></li>
                    <li><a href="#">Contact Us</a></li>
                    <li><a href="#">Become an Instructor</a></li>
                    <li><a href="#">FAQs</a></li>
                </ul>
            </div>
            <div class="footer-links">
                <h3 class="footer-title">Courses</h3>
                <ul>
                    <li><a href="#">Web Development</a></li>
                    <li><a href="#">UI / UX</a></li>
                    <li><a href="#">Data Science</a></li>
                    <li><a href="#">Business</a></li>
                    <li><a href="#">Artificial Intelligence</a></li>
                </ul>
            </div>
            <div class="footer-apps">
                <h3 class="footer-title">Download App</h3>
                <p>Download our mobile app and learn on the go.</p>
                <img src="~/Images/app store.png" alt="App Store">
                <img src="~/Images/goagle play.png" alt="Google Play">
            </div>
        </div>
        <hr>
        <div class="footer-bottom">
            <p>© 2026 Learnio. All Rights Reserved.</p>
            <div class="bottom-links">
                <a href="#">Terms & Conditions</a>
                <a href="#">Privacy Policy</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/register.js"></script>
</body>
</html>
