@model IEnumerable<CourseManagment.BLL.ViewModels.PaymentVm.PaymentCardViewModel>

@{
    ViewData["Title"] = "My Payments";
}

<div class="container py-5">

    <h2 class="fw-bold mb-4">

        My Payments

    </h2>

    <div class="card shadow border-0 rounded-4">

        <div class="card-body">

            <table class="table align-middle">

                <thead>

                    <tr>

                        <th>Course</th>

                        <th>Amount</th>

                        <th>Status</th>

                        <th>Date</th>

                        <th></th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.CourseTitle</td>

                            <td>$@item.Amount</td>

                            <td>

                                @if (item.Status == CourseManagment.DAL.Enums.PaymentStatus.Paid)
                                {
                                    <span class="badge bg-success">
                                        Paid
                                    </span>
                                }
                                else if (item.Status == CourseManagment.DAL.Enums.PaymentStatus.Pending)
                                {
                                    <span class="badge bg-warning text-dark">
                                        Pending
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        @item.Status
                                    </span>
                                }

                            </td>

                            <td>

                                @item.PaymentDate.ToString("dd MMM yyyy")

                            </td>

                            <td>

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary">

                                    Details

                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>