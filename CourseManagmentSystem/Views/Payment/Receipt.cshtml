@model CourseManagment.BLL.ViewModels.PaymentVm.PaymentDetailsViewModel

@{
    ViewData["Title"] = "Receipt";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow border-0 rounded-4">

                <div class="card-body p-5">

                    <div class="text-center">

                        <h2 class="fw-bold">

                            Learnio

                        </h2>

                        <p class="text-muted">

                            Payment Receipt

                        </p>

                    </div>

                    <hr />

                    <table class="table table-borderless">

                        <tr>

                            <th width="40%">
                                Course
                            </th>

                            <td>
                                @Model.CourseTitle
                            </td>

                        </tr>

                        <tr>

                            <th>
                                Student
                            </th>

                            <td>
                                @Model.UserName
                            </td>

                        </tr>

                        <tr>

                            <th>
                                Amount
                            </th>

                            <td>

                                $@Model.Amount

                            </td>

                        </tr>

                        <tr>

                            <th>
                                Method
                            </th>

                            <td>

                                @Model.PaymentMethod

                            </td>

                        </tr>

                        <tr>

                            <th>
                                Status
                            </th>

                            <td>

                                <span class="badge bg-success">

                                    @Model.Status

                                </span>

                            </td>

                        </tr>

                        <tr>

                            <th>
                                Transaction ID
                            </th>

                            <td>

                                @Model.TransactionId

                            </td>

                        </tr>

                        <tr>

                            <th>
                                Payment Date
                            </th>

                            <td>

                                @Model.PaymentDate.ToString("dd MMM yyyy hh:mm tt")

                            </td>

                        </tr>

                    </table>

                    <div class="text-center mt-4">

                        <button class="btn btn-dark"
                                onclick="window.print()">

                            <i class="bi bi-printer"></i>

                            Print Receipt

                        </button>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>