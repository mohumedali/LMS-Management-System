@model CourseManagment.BLL.ViewModels.PaymentVm.PaymentDetailsViewModel

@{
    ViewData["Title"] = "Payment Failed";
}

<div class="container py-5">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-body text-center p-5">

                    <div class="mb-4">
                        <i class="bi bi-x-circle-fill text-danger" style="font-size:80px"></i>
                    </div>

                    <h2 class="fw-bold text-danger">
                        Payment Failed
                    </h2>

                    <p class="text-muted mb-4">
                        Your payment could not be processed. This demo card was
                        set up to simulate a declined transaction.
                    </p>

                    <hr />

                    <div class="row text-start mt-4">

                        <div class="col-6 fw-semibold">Course</div>
                        <div class="col-6 text-end">@Model.CourseTitle</div>

                        <div class="col-6 fw-semibold mt-3">Amount</div>
                        <div class="col-6 text-end mt-3">$@Model.Amount.ToString("0.00")</div>

                        <div class="col-6 fw-semibold mt-3">Payment Method</div>
                        <div class="col-6 text-end mt-3">@Model.PaymentMethod</div>

                        <div class="col-6 fw-semibold mt-3">Reference</div>
                        <div class="col-6 text-end mt-3">@Model.TransactionId</div>

                    </div>

                    <div class="mt-5 d-flex justify-content-center gap-2">

                        <a asp-action="Create"
                           asp-route-enrollmentId="@Model.EnrollmentId"
                           asp-route-amount="@Model.Amount"
                           class="btn btn-danger px-4">
                            <i class="fa-solid fa-rotate-right me-1"></i>
                            Try Again
                        </a>

                        <a asp-controller="Course"
                           asp-action="Index"
                           class="btn btn-outline-secondary px-4">
                            Back To Courses
                        </a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>
