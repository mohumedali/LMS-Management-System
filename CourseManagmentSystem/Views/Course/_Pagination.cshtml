@model CourseManagment.DAL.Common.PaginatedResult<CourseManagment.BLL.ViewModels.CoursesVM.GetCourseViewModel>


<link rel="stylesheet" href="~/css/theme.css" />

@{
    int totalPages = (int)Math.Ceiling((double)Model.TotalItems / Model.PageSize);

    if (totalPages <= 1)
    {
        return;
    }
}

<nav class="mt-5">

    <ul class="pagination justify-content-center">

        <!-- Previous -->

        <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">

            <a class="page-link"
               asp-action="Index"
               asp-route-page="@(Model.CurrentPage - 1)">
                Previous
            </a>

        </li>

        @for (int i = 1; i <= totalPages; i++)
        {
            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">

                <a class="page-link"
                   asp-action="Index"
                   asp-route-page="@i">
                    @i
                </a>

            </li>
        }

        <!-- Next -->

        <li class="page-item @(Model.CurrentPage == totalPages ? "disabled" : "")">

            <a class="page-link"
               asp-action="Index"
               asp-route-page="@(Model.CurrentPage + 1)">
                Next
            </a>

        </li>

    </ul>

</nav>