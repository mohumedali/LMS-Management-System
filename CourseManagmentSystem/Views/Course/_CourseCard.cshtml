@model CourseManagment.BLL.ViewModels.CoursesVM.GetCourseViewModel


<link rel="stylesheet" href="~/css/theme.css" />


<div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden course-card">

    <!-- Course Image -->
    <img src="~/Images/@Model.ImageUrl"
         class="card-img-top"
         alt="@Model.Title" />

    <div class="card-body d-flex flex-column">

        <!-- Category -->
        <span class="badge bg-success mb-2 align-self-start">
            @Model.CategoryName
        </span>

        <!-- Title -->
        <h5 class="fw-bold">
            @Model.Title
        </h5>

        <!-- Instructor -->
        <p class="text-muted mb-2">
            <i class="bi bi-person-circle"></i>
            @Model.InstructorName
        </p>

        <!-- Description -->
        <p class="text-muted small flex-grow-1">
            @(Model.Description.Length > 110
                ? Model.Description.Substring(0, 110) + "..."
                : Model.Description)
        </p>

        <!-- Course Info -->

        <div class="d-flex justify-content-between mb-3">

            <span class="badge bg-light text-dark">
                <i class="bi bi-clock"></i>
                @Model.Duration hrs
            </span>

            <span class="badge bg-secondary">
                @Model.Level
            </span>

        </div>

        <!-- Price -->

        <div class="d-flex justify-content-between align-items-center">

            <div>

                <span class="fs-4 fw-bold text-success">
                    $@Model.Price
                </span>

            </div>

            <a asp-action="Details"
               asp-route-id="@Model.Id"
               class="btn btn-success rounded-pill">

                View Details

            </a>

        </div>

    </div>

</div>
