@model CourseManagment.BLL.ViewModels.CoursesVM.CourseIndexViewModel

<link rel="stylesheet" href="~/css/theme.css" />

<div class="card shadow-sm border-0">

    <div class="card-header bg-success text-white">
        <h5 class="mb-0">
            <i class="bi bi-funnel-fill me-2"></i>
            Filters
        </h5>
    </div>

    <div class="card-body">

        <form asp-action="Index" method="get">

            <!-- Search -->

            <div class="mb-4">

                <label class="form-label fw-bold">
                    Search
                </label>

                <input type="text"
                       name="Search"
                       value="@Model.Filter?.Search"
                       class="form-control"
                       placeholder="Course title..." />

            </div>

            <!-- Category -->

            <div class="mb-4">

                <label class="form-label fw-bold">
                    Categories
                </label>

                @foreach (var category in Model.Categories)
                {
                    <div class="form-check">

                        <input class="form-check-input"
                               type="checkbox"
                               name="CategoryIds"
                               value="@category.Id"
                        @(Model.Filter?.CategoryIds?.Contains(category.Id) == true ? "checked" : "") />

                        <label class="form-check-label">
                            @category.Name
                        </label>

                    </div>
                }

            </div>

            <!-- Instructor -->

            <div class="mb-4">

                <label class="form-label fw-bold">
                    Instructors
                </label>

                @foreach (var instructor in Model.Instructors)
                {
                    <div class="form-check">

                        <input class="form-check-input"
                               type="checkbox"
                               name="InstructorIds"
                               value="@instructor.Id"
                        @(Model.Filter?.InstructorIds?.Contains(instructor.Id) == true ? "checked" : "") />

                        <label class="form-check-label">
                            @instructor.FullName
                        </label>

                    </div>
                }

            </div>

            <!-- Level -->

            <div class="mb-4">

                <label class="form-label fw-bold">
                    Level
                </label>

                @foreach (var level in Enum.GetValues<CourseManagment.DAL.Enums.CourseLevel>())
                {
                    <div class="form-check">

                        <input class="form-check-input"
                               type="checkbox"
                               name="Levels"
                               value="@level"
                        @(Model.Filter?.Levels?.Contains(level) == true ? "checked" : "") />

                        <label class="form-check-label">
                            @level
                        </label>

                    </div>
                }

            </div>

            <!-- Price -->

            <div class="mb-4">

                <label class="form-label fw-bold">
                    Price
                </label>

                <div class="row">

                    <div class="col">

                        <input type="number"
                               name="MinPrice"
                               value="@Model.Filter?.MinPrice"
                               class="form-control"
                               placeholder="Min" />

                    </div>

                    <div class="col">

                        <input type="number"
                               name="MaxPrice"
                               value="@Model.Filter?.MaxPrice"
                               class="form-control"
                               placeholder="Max" />

                    </div>

                </div>

            </div>


            <!-- Buttons -->

            <div class="d-grid gap-2">

                <button class="btn btn-success">

                    <i class="bi bi-search me-1"></i>

                    Apply Filters

                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary">

                    Clear

                </a>

            </div>

        </form>

    </div>

</div>