<style>

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: "Poppins", sans-serif;
    }

    .footer {
        /* background:#e9f2f1; */
        padding: 80px 0 20px;
    }

    .footer-container {
        width: 90%;
        max-width: 1200px;
        margin: auto;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 40px;
    }

    .footer-about, .footer-links, .footer-apps {
        flex: 1;
    }

    .footer-logo {
        display: flex;
        align-items: center;
        gap: 5px;
        margin-bottom: 30px;
    }

        .footer-logo img {
            width: 55px;
        }

        .footer-logo h2 {
            font-family: "Outfit", sans-serif;
            font-size: 38px;
            font-weight: 800;
            color: #0F766E;
        }

    .footer-title {
        position: relative;
        display: inline-block;
        margin-bottom: 35px;
        font-weight: 500;
        color: #0F766E;
        font-size: 25px;
    }




    .footer-about p {
        color: #333;
        ;
        margin-bottom: 18px;
        font-size: 17px;
        line-height: 1.6;
    }

        .footer-about p i {
            color: #333;
            ;
            margin-right: 10px;
            font-size: 18px;
        }

    .footer-about h3 {
        margin: 30px 0 12px;
        font-size: 25px;
        color: #333;
        ;
    }

    .social-icons {
        display: flex;
        gap: 15px;
    }

        .social-icons a {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: #0F766E;
            color: white;
            text-decoration: none;
            display: flex;
            justify-content: center;
            align-items: center;
            transition: .4s;
        }


    .footer-title::before,
    .footer-title::after {
        content: "";
        position: absolute;
        bottom: -15px;
        height: 4px;
        background: #0F766E;
        border-radius: 10px;
    }

    .footer-title::before {
        width: 18px;
        left: 0;
        animation: line1 2s infinite alternate ease-in-out;
    }

    .footer-title::after {
        width: 40px;
        left: 24px;
        animation: line2 2s infinite alternate ease-in-out;
    }

    keyframes line1 {
        from {
            left: 0;
        }

        to {
            left: 45px;
        }
    }

    keyframes line2 {
        from {
            left: 24px;
        }

        to {
            left: 0;
        }
    }


    .social-icons a:hover {
        background: #134e4a;
        transform: translateY(-5px);
    }

    .footer-links ul {
        list-style: none;
        padding: 0;
        margin: 15px 0 0;
    }

        .footer-links ul li {
            margin-bottom: 18px;
        }

            .footer-links ul li a {
                display: block;
                text-decoration: none;
                color: #333;
                font-size: 17px;
                transition: .3s;
            }

                .footer-links ul li a:hover {
                    color: #0F766E;
                    padding-left: 8px;
                }

    .footer-apps p {
        color: #333;
        line-height: 1.8;
        margin-bottom: 20px;
    }

    .footer-apps img {
        width: 170px;
        display: block;
        margin-bottom: 15px;
        cursor: pointer;
        transition: .3s;
    }

        .footer-apps img:hover {
            transform: scale(1.05);
        }

    .footer hr {
        width: 90%;
        margin: 60px auto 25px;
        border: none;
        height: 1px;
        background: #adb6b4;
    }

    .footer-bottom {
        width: 90%;
        max-width: 1200px;
        margin: auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .footer-bottom p {
            color: #6b7280;
        }

    .bottom-links {
        display: flex;
        gap: 30px;
    }

        .bottom-links a {
            text-decoration: none;
            color: #6b7280;
            transition: .3s;
        }

            .bottom-links a:hover {
                color: #0F766E;
            }





    /* ================= Tablet ================= */

    @@media (max-width:992px) {

        .footer {
            padding: 60px 0 20px;
        }

        .footer-container {
            flex-wrap: wrap;
            gap: 50px;
        }

        .footer-about,
        .footer-links,
        .footer-apps {
            flex: 0 0 calc(50% - 25px);
        }

        .footer-bottom {
            flex-direction: column;
            gap: 20px;
            text-align: center;
        }

        .bottom-links {
            justify-content: center;
        }
    }


    /* ================= Mobile ================= */

    @@media (max-width:768px) {

        .footer {
            padding: 50px 0 20px;
        }

        .footer-container {
            flex-direction: column;
            gap: 45px;
        }

        .footer-about,
        .footer-links,
        .footer-apps {
            width: 100%;
        }

        .footer-logo {
            justify-content: center;
        }

        .footer-about {
            text-align: center;
        }

            .footer-about p {
                justify-content: center;
            }

        .social-icons {
            justify-content: center;
        }

        .footer-links {
            text-align: center;
        }

        .footer-title {
            display: inline-block;
        }

        .footer-links ul li a:hover {
            padding-left: 0;
        }

        .footer-apps {
            text-align: center;
        }

            .footer-apps img {
                margin: 15px auto;
            }

        .footer-bottom {
            flex-direction: column;
            text-align: center;
            gap: 15px;
        }

        .bottom-links {
            flex-direction: column;
            gap: 10px;
            align-items: center;
        }
    }


    /* ================= Small Mobile ================= */

    @@media (max-width:480px) {

        .footer-logo h2 {
            font-size: 32px;
        }

        .footer-title {
            font-size: 22px;
        }

        .footer-about h3 {
            font-size: 22px;
        }

        .footer-about p,
        .footer-links a,
        .footer-apps p {
            font-size: 16px;
        }

        .footer-apps img {
            width: 150px;
        }

        .social-icons a {
            width: 42px;
            height: 42px;
        }
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }



    body {
        font-family: "Poppins", sans-serif;
        overflow-x: hidden;
    }

    .navbar-brand {
        color: #0F766E !important;
        font-size: 42px;
    }

    .nav-link {
        color: #333;
    }

        .nav-link:hover {
            color: #0F766E;
        }

    .input-group {
        max-width: 500px;
        width: 100%;
    }

    .form-control {
        border: 1px solid #ddd;
        box-shadow: none;
    }

        .form-control:focus {
            box-shadow: none;
            border-color: #0F766E;
        }

    /* Login */
    .navbar .nav-link {
        color: #2b3645;
        font-weight: 500;
        transition: 0.3s;
    }

        .navbar .nav-link:hover {
            color: #0F766E;
        }



    .navbar .register-btn {
        color: #0F766E;
        border: 2px solid #0F766E;
        background: transparent;
        transition: 0.3s;
    }

        .navbar .register-btn:hover {
            background: #c5e3dc;
            color: #0F766E;
            border: 2px solid #0F766E;
        }

    .course-hero {
        border-radius: 20px;
    }

    .card {
        border: none;
        border-radius: 16px;
    }

    .accordion-button {
        font-weight: 600;
    }

    .accordion-item {
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 10px;
    }

    .list-group-item {
        border: none;
        padding: 15px 0;
    }

    /* .sticky-top {
            z-index: 1;
        } */

    .btn-primary {
        border-radius: 12px;
    }

    .btn-outline-dark {
        border-radius: 12px;
    }

    .rounded-circle {
        object-fit: cover;
    }

    .card:hover {
        transition: .3s;
        transform: translateY(-2px);
    }
</style>