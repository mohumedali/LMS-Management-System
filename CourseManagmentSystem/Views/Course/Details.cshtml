@model CourseManagment.BLL.ViewModels.CoursesVM.CourseDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
}


<nav class="navbar navbar-expand-lg bg-white shadow-sm sticky-top py-3">
    <div class="container">

        <!-- Logo -->
        <a class="navbar-brand fw-bold fs-1 " asp-controller="Home" asp-action="Index">
            Learnio
        </a>

        <!-- Mobile Button -->
        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarContent">

            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarContent">

            <!-- Categories -->
            <ul class="navbar-nav ms-3">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle fw-semibold"
                       href="#"
                       data-bs-toggle="dropdown">
                        Categories
                    </a>

                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">Development</a></li>
                        <li><a class="dropdown-item" href="#">IT & Software</a></li>
                        <li><a class="dropdown-item" href="#">UI / UX Design</a></li>
                        <li><a class="dropdown-item" href="#">Data Science</a></li>
                        <li><a class="dropdown-item" href="#">Artificial Intelligence</a></li>
                        <li><a class="dropdown-item" href="#">Business</a></li>
                        <li><a class="dropdown-item" href="#">Software Testing</a></li>
                        <li><a class="dropdown-item" href="#">Personal Development</a></li>
                    </ul>
                </li>
            </ul>

            <!-- Search -->
            <form class="d-flex flex-grow-1 mx-lg-4 my-3 my-lg-0">

                <div class="input-group">

                    <input type="text"
                           class="form-control rounded-start-pill border-end-0"
                           placeholder="What do you want to learn?">

                    <button class="btn btn-success rounded-end-pill px-4">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>

                </div>

            </form>

            <!-- Links -->
            <ul class="navbar-nav">

                <li class="nav-item">
                    <a class="nav-link fw-semibold" asp-controller="Home" asp-action="Index">Home</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link fw-semibold" asp-controller="Course" asp-action="Index">Courses</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link fw-semibold" asp-controller="Enrollment" asp-action="MyLearning">My Coursers</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link fw-semibold" asp-controller="Profile" asp-action="Index">Profile</a>
                </li>


            </ul>

            <!-- Actions -->
            <div class="d-flex align-items-center ms-lg-3">

                <a asp-controller="Account" asp-action="Login" class="nav-link fw-semibold me-3">
                    <i class="fa-solid fa-right-to-bracket"></i>
                    Login
                </a>

                <a asp-controller="Account" asp-action="Register" class="btn  register-btn rounded-3 px-4">
                    <i class="fa-regular fa-user me-1"></i>
                    Register
                </a>

            </div>

        </div>

    </div>
</nav>
<div class="container mt-5">

    <div class="row">

        <!-- Left -->

        <div class="col-lg-8">

            <img src="~/Images/@Model.ImageUrl"
                 class="img-fluid rounded shadow mb-4 w-100"
                 style="height:420px;object-fit:cover;">

            <h2 class="fw-bold">
                @Model.Title
            </h2>

            <div class="mb-3">

                <span class="badge bg-success">
                    @Model.Category
                </span>

                <span class="badge bg-warning text-dark">
                    @Model.Level
                </span>

            </div>

            <p class="text-muted fs-5">

                @Model.Description

            </p>

            <hr />

            <h4 class="fw-bold mb-3">

                Course Content

            </h4>

            <div class="accordion" id="lessonAccordion">

                @foreach (var lesson in Model.Lessons)
                {
                    <div class="accordion-item">

                        <h2 class="accordion-header">

                            <button class="accordion-button collapsed"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#lesson@lesson.Id">

                                @lesson.Title

                            </button>

                        </h2>

                        <div id="lesson@lesson.Id"
                             class="accordion-collapse collapse"
                             data-bs-parent="#lessonAccordion">

                            <div class="accordion-body">

                                <span class="badge bg-info">

                                    @lesson.Duration

                                </span>

                            </div>

                        </div>

                    </div>
                }

            </div>

            <hr class="my-5" />

            <h4 class="fw-bold">

                Reviews (@Model.ReviewsCount)

            </h4>

            @foreach (var review in Model.Reviews)
            {
                <div class="card shadow-sm border-0 mb-3">

                    <div class="card-body">

                        <h6 class="fw-bold">

                            @review.StudentName

                        </h6>

                        <div class="text-warning">

                            @for (int i = 0; i < review.Rating; i++)
                            {
                                <i class="bi bi-star-fill"></i>
                            }

                        </div>

                        <p class="mt-2">

                            @review.Comment

                        </p>

                    </div>

                </div>
            }

        </div>

        <!-- Right -->

        <div class="col-lg-4">

            <div class="card shadow position-sticky">

                <div class="card-body">

                    <h2 class="text-success fw-bold">

                        $@Model.Price

                    </h2>

                    <div class="mb-3">

                        <strong>

                            ⭐ @Model.AverageRating.ToString("0.0")

                        </strong>

                        (@Model.ReviewsCount Reviews)

                    </div>

                    <a asp-controller="Enrollment"
                       asp-action="Confirm"
                       asp-route-courseId="@Model.Id"
                       class="btn btn-success w-100 mb-2">
                        Enroll Now
                    </a>
                    <a asp-controller="course"
                       asp-action="Index"
                       class="btn btn-secondary w-100 mb-2">
                        Back To Courses
                    </a>

                    <hr />

                    <ul class="list-group list-group-flush">

                        <li class="list-group-item">

                            <i class="bi bi-clock"></i>

                            Duration :
                            @Model.Duration hrs

                        </li>

                        <li class="list-group-item">

                            <i class="bi bi-globe"></i>

                            Language :
                            @Model.Language

                        </li>

                        <li class="list-group-item">

                            <i class="bi bi-person"></i>

                            InstructorName :
                            @Model.InstructorName

                        </li>

                    </ul>

                </div>

            </div>

            <div class="card mt-4 shadow">

                <div class="card-body text-center">

                    <img src="~/Images/@Model.InstructorImage"
                         class="rounded-circle mb-3"
                         width="110"
                         height="110">

                    <h5>

                        @Model.InstructorName

                    </h5>

                    <p class="text-muted">

                        @Model.InstructorBio

                    </p>

                </div>

            </div>

        </div>

    </div>

</div>
