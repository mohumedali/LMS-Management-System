                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Course" asp-action="Index">Courses</a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link fw-semibold" asp-controller="Enrollment" asp-action="MyLearning">My Courses</a>
                    </li>

                    <li class="nav-item">
