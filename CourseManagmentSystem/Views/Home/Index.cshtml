    <section class="types container">
        <div class="types-header">

            <div class="types-title">

                <span>Categories</span>

                <h2 class="type-title">Popular Categories</h2>

            </div>

            <a href="#" class="types-btn">
                All Categories
                <i class="fa-solid fa-arrow-right"></i>
            </a>

        </div>

        <div class="container">

       

            <div class="types-cards">

                <!-- Card 1 -->
                @foreach (var item in Model.Categories)
                {


                    <div class="types-card">

                        <img src="~/Images/@item.ImageUrl" asp-append-version="true" />

                        <div class="types-overlay"></div>

                        <div class="types-content">

                            <h3>@item.Name</h3>

                            <p>@item.CoursesCount Courses</p>

                            <a asp-controller="Course" asp-action="Index" class="explore-btn">
                                Explore
                                <i class="fa-solid fa-arrow-right"></i>
                            </a>

                        </div>

                    </div>
                }
            </div>

        </section>
        <!-- /////////////////////////////////////// -->
        <section class="courses">

            <!-- Title -->

            <div class="courses-title">

                <span>Choose your desired courses</span>

                <h2 class="big-title">
                    The world's largest selection of courses
                </h2>

            </div>

            <div class="container">

        

        
                <div class="course-tabs">

                    @for (int i = 0; i < Model.Categories.Count(); i++)
                    {
                        var category = Model.Categories.ElementAt(i);

                        <a href="#"
                           class="tab @(i == 0 ? "active" : "")"
                           data-tab="@category.Id">

                            @category.Name

                        </a>
                    }

                </div>

                @for (int i = 0; i < Model.Categories.Count(); i++)
                {
                    var category = Model.Categories.ElementAt(i);

                    <div class="tab-content @(i == 0 ? "active" : "")"
                         id="@category.Id">

                        @foreach (var course in Model.PopularCourses.Where(c => c.CategoryId == category.Id))
                        {
                            <div class="course-card">

                                <div class="course-img">

                                    <img src="~/Images/@course.ImageUrl" class="rounded-bottom" alt="@course.Title">

                                    <div class="course-badges">

                                        @if (course.IsBestSeller)
                                        {
                                            <span class="badge orange">Bestseller</span>
                                        }

                                        @if (course.IsHighestRated)
                                        {
                                            <span class="badge orange">Highest Rated</span>
                                        }

                                        @if (course.DiscountPercentage > 0)
                                        {
                                            <span class="badge blue">
                                                -@course.DiscountPercentage%
                                            </span>
                                        }

                                    </div>

                                </div>

                                <div class="course-info">

                                    <span class="level">@course.Level</span>

                                    <h3>@course.Title</h3>

                                    <p class="teacher">
                                        <i class="fa-solid fa-user"></i>
                                        @course.InstructorName
                                    </p>

                                    <div class="course-details">

                                        <span>
                                            <i class="fa-solid fa-user-group"></i>
                                            @course.StudentsCount Student
                                        </span>

                                        <span>
                                            <i class="fa-solid fa-book-open"></i>
                                            @course.LessonsCount Lessons
                                        </span>

                                    </div>

                                    <div class="price">

                                        @if (course.OldPrice.HasValue)
                                        {
                                            <del>$@course.OldPrice</del>
                                        }

                                        <h4 class="text-success fw-bold">$@course.Price</h4>

                                    </div>

                                </div>

                                <!-- Hover -->
                                <div class="course-hover overflow-hidden">

                                    <span class="author">@course.InstructorName</span>

                                    <h3>@course.Title</h3>

                                    <div class="course-meta">

                                        @if (course.IsBestSeller)
                                        {
                                            <span class="best">Bestseller</span>
                                        }

                                        @if (course.IsHighestRated)
                                        {
                                            <span class="best">Highest Rated</span>
                                        }

                                        <span class="updated">@course.Level</span>

                                    </div>

                                    <p>
                                        @course.Description
                                    </p>

                                    <ul>

                                        <li>
                                            <i class="fa-solid fa-layer-group"></i>
                                            @course.CategoryName
                                        </li>

                                        <li>
                                            <i class="fa-solid fa-book-open"></i>
                                            @course.LessonsCount Lessons
                                        </li>

                                        <li>
                                            <i class="fa-solid fa-user-group"></i>
                                            @course.StudentsCount Students
                                        </li>

                                        <li>
                                            <i class="fa-solid fa-dollar-sign"></i>
                                            $@course.Price
                                        </li>

                                    </ul>

                                    <div class="hover-btns">

                                        <a asp-controller="Enrollment"
                                           asp-action="Confirm"
                                           asp-route-courseId="@course.Id"
                                           class="cart-btn">

                                            <i class="fa-solid fa-graduation-cap"></i>
                                            Enroll Now

                                        </a>

                                        <button class="wish-btn">
                                            <i class="fa-regular fa-heart"></i>
                                        </button>

                                    </div>

                                </div>

                            </div>
                        }

                    </div>

                }


            </section>



