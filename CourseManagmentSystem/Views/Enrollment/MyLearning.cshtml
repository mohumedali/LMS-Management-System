@model IEnumerable<CourseManagment.BLL.ViewModels.EnrollmentVm.EnrollmentCardViewModel>

@{
    ViewData["Title"] = "My Learning";
}

<nav class="navbar navbar-expand-lg bg-white shadow-sm sticky-top py-3">
    <div class="container">

        <!-- Logo -->
        <a class="navbar-brand fw-bold fs-1 " asp-controller="Home" asp-action="Index">
            Learnio
        </a>

        <!-- Mobile Button -->
        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarContent">

            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarContent">

            <!-- Categories -->
            <ul class="navbar-nav ms-3">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle fw-semibold"
                       href="#"
                       data-bs-toggle="dropdown">
                        Categories
                    </a>

                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">Development</a></li>
                        <li><a class="dropdown-item" href="#">IT & Software</a></li>
                        <li><a class="dropdown-item" href="#">UI / UX Design</a></li>
                        <li><a class="dropdown-item" href="#">Data Science</a></li>
                        <li><a class="dropdown-item" href="#">Artificial Intelligence</a></li>
                        <li><a class="dropdown-item" href="#">Business</a></li>
                        <li><a class="dropdown-item" href="#">Software Testing</a></li>
                        <li><a class="dropdown-item" href="#">Personal Development</a></li>
                    </ul>
                </li>
            </ul>

            <!-- Search -->
            <form class="d-flex flex-grow-1 mx-lg-4 my-3 my-lg-0">

                <div class="input-group">

                    <input type="text"
                           class="form-control rounded-start-pill border-end-0"
                           placeholder="What do you want to learn?">

                    <button class="btn btn-success rounded-end-pill px-4">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>

                </div>

            </form>

            <!-- Links -->
            <ul class="navbar-nav">

                <li class="nav-item">
                    <a class="nav-link fw-semibold" asp-controller="Home" asp-action="Index">Home</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link fw-semibold" asp-controller="Course" asp-action="Index">Courses</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link fw-semibold" asp-controller="Enrollment" asp-action="MyLearning">My Coursers</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link fw-semibold" asp-controller="Profile" asp-action="Index">Profile</a>
                </li>


            </ul>

            <!-- Actions -->
            <div class="d-flex align-items-center ms-lg-3">

                <a asp-controller="Account" asp-action="Login" class="nav-link fw-semibold me-3">
                    <i class="fa-solid fa-right-to-bracket"></i>
                    Login
                </a>

                <a asp-controller="Account" asp-action="Register" class="btn  register-btn rounded-3 px-4">
                    <i class="fa-regular fa-user me-1"></i>
                    Register
                </a>

            </div>

        </div>

    </div>
</nav>



<div class="container py-5">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-warning">
            @TempData["Error"]
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">
                <i class="bi bi-mortarboard-fill text-success"></i>
                My Learning
            </h2>

            <p class="text-muted mb-0">
                Continue learning from your enrolled courses.
            </p>
        </div>

        <a asp-controller="Course"
           asp-action="Index"
           class="btn btn-success">

            <i class="bi bi-plus-circle me-1"></i>

            Browse Courses

        </a>

    </div>

    @if (!Model.Any())
    {
        <div class="card shadow border-0">

            <div class="card-body text-center py-5">

                <i class="bi bi-book display-2 text-secondary"></i>

                <h3 class="mt-3">
                    No Courses Yet
                </h3>

                <p class="text-muted">
                    You haven't enrolled in any courses.
                </p>

                <a asp-controller="Course"
                   asp-action="Index"
                   class="btn btn-success">

                    Explore Courses

                </a>

            </div>

        </div>
    }
    else
    {
        <div class="row g-4">

            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6">

                    <div class="card learning-card h-100 border-0 shadow-sm">

                        <img src="~/Images/@item.CourseImage"
                             asp-append-version="true"
                             class="card-img-top"
                             style="height:220px;object-fit:cover;">

                        <div class="card-body d-flex flex-column">

                            <h5 class="fw-bold">
                                @item.CourseTitle
                            </h5>

                            <p class="text-muted mb-2">
                                <i class="bi bi-person-circle"></i>
                                @item.InstructorName
                            </p>

                            <p class="small text-muted">

                                <i class="bi bi-calendar-event"></i>

                                Enrolled:
                                @item.EnrollmentDate.ToString("dd MMM yyyy")

                            </p>

                            <div class="mb-3">

                                @switch (item.Status)
                                {
                                    case "Active":

                                        <span class="badge bg-success">
                                            Active
                                        </span>

                                        break;

                                    case "Completed":

                                        <span class="badge bg-primary">
                                            Completed
                                        </span>

                                        break;

                                    case "Cancelled":

                                        <span class="badge bg-danger">
                                            Cancelled
                                        </span>

                                        break;

                                    default:

                                        <span class="badge bg-secondary">
                                            @item.Status
                                        </span>

                                        break;
                                }

                            </div>

                            <div class="mt-auto d-grid gap-2">

                                <a asp-action="Details"
                                   asp-route-id="@item.EnrollmentId"
                                   class="btn btn-success">

                                    <i class="bi bi-eye"></i>

                                    Details

                                </a>

                                @if (item.Status == "Active")
                                {
                                    <form asp-action="Cancel"
                                          method="post">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden"
                                               name="id"
                                               value="@item.EnrollmentId" />

                                        <button class="btn btn-outline-danger w-100">

                                            <i class="bi bi-x-circle"></i>

                                            Cancel Enrollment

                                        </button>

                                    </form>
                                }

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }

</div>

