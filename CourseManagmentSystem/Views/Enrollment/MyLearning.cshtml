<style>
    .learning-card {
        border-radius: 18px;
        overflow: hidden;
        transition: .3s;

    }

        .learning-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 15px 35px rgba(0,0,0,.12) !important;
        }

        .learning-card img {
            transition: .4s;
        }

        .learning-card:hover img {
            transform: scale(1.05);
        }

        .learning-card .badge {
            font-size: .8rem;
            padding: .55rem .9rem;
        }

        .learning-card .btn {
            border-radius: 10px;
        }

        .learning-card h5 {
            min-height: 55px;
        }
</style>