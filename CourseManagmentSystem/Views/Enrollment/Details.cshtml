@model CourseManagment.BLL.ViewModels.EnrollmentVm.EnrollmentDetailsViewModel

@{
    ViewData["Title"] = "Enrollment Details";
}

<nav class="navbar navbar-expand-lg bg-white shadow-sm sticky-top py-3">
    <div class="container">

        <!-- Logo -->
        <a class="navbar-brand fw-bold fs-1 " asp-controller="Home" asp-action="Index">
            Learnio
        </a>

        <!-- Mobile Button -->
        <button class="navbar-toggler border-0" type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbarContent">

            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarContent">

            <!-- Categories -->
            <ul class="navbar-nav ms-3">
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle fw-semibold"
                       href="#"
                       data-bs-toggle="dropdown">
                        Categories
                    </a>

                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">Development</a></li>
                        <li><a class="dropdown-item" href="#">IT & Software</a></li>
                        <li><a class="dropdown-item" href="#">UI / UX Design</a></li>
                        <li><a class="dropdown-item" href="#">Data Science</a></li>
                        <li><a class="dropdown-item" href="#">Artificial Intelligence</a></li>
                        <li><a class="dropdown-item" href="#">Business</a></li>
                        <li><a class="dropdown-item" href="#">Software Testing</a></li>
                        <li><a class="dropdown-item" href="#">Personal Development</a></li>
                    </ul>
                </li>
            </ul>

            <!-- Search -->
            <form class="d-flex flex-grow-1 mx-lg-4 my-3 my-lg-0">

                <div class="input-group">

                    <input type="text"
                           class="form-control rounded-start-pill border-end-0"
                           placeholder="What do you want to learn?">

                    <button class="btn btn-success rounded-end-pill px-4">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>

                </div>

            </form>

            <!-- Links -->
            <ul class="navbar-nav">

                <li class="nav-item">
                    <a class="nav-link fw-semibold" asp-controller="Home" asp-action="Index">Home</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link fw-semibold" asp-controller="Course" asp-action="Index">Courses</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link fw-semibold" asp-controller="Enrollment" asp-action="MyLearning">My Coursers</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link fw-semibold" asp-controller="Profile" asp-action="Index">Profile</a>
                </li>


            </ul>

            <!-- Actions -->
            <div class="d-flex align-items-center ms-lg-3">

                <a asp-controller="Account" asp-action="Login" class="nav-link fw-semibold me-3">
                    <i class="fa-solid fa-right-to-bracket"></i>
                    Login
                </a>

                <a asp-controller="Account" asp-action="Register" class="btn  register-btn rounded-3 px-4">
                    <i class="fa-regular fa-user me-1"></i>
                    Register
                </a>

            </div>

        </div>

    </div>
</nav>


<div class="container py-5">

    <div class="row">

        <!-- ================= Course ================= -->

        <div class="col-lg-8">

            <div class="card shadow-lg border-0 mb-4">

                <img src="~/Images/@Model.ImageUrl"
                     asp-append-version="true"
                     class="card-img-top"
                     style="height:420px;object-fit:cover;" />

                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-start">

                        <div>

                            <h2 class="fw-bold">
                                @Model.Title
                            </h2>

                            <p class="text-muted">
                                @Model.Category
                            </p>

                        </div>

                        <h3 class="text-success fw-bold">
                            $@Model.Price
                        </h3>

                    </div>

                    <hr />

                    <p class="text-muted fs-6">

                        @Model.Description

                    </p>

                    <div class="row mt-4">

                        <div class="col-md-3 mb-3">

                            <div class="border rounded-3 p-3 text-center">

                                <i class="bi bi-clock-history fs-2 text-primary"></i>

                                <h6 class="mt-2 mb-0">
                                    @Model.Duration Hours
                                </h6>

                                <small class="text-muted">
                                    Duration
                                </small>

                            </div>

                        </div>

                        <div class="col-md-3 mb-3">

                            <div class="border rounded-3 p-3 text-center">

                                <i class="bi bi-translate fs-2 text-success"></i>

                                <h6 class="mt-2 mb-0">
                                    @Model.Language
                                </h6>

                                <small class="text-muted">
                                    Language
                                </small>

                            </div>

                        </div>

                        <div class="col-md-3 mb-3">

                            <div class="border rounded-3 p-3 text-center">

                                <i class="bi bi-bar-chart fs-2 text-warning"></i>

                                <h6 class="mt-2 mb-0">
                                    @Model.Level
                                </h6>

                                <small class="text-muted">
                                    Level
                                </small>

                            </div>

                        </div>

                        <div class="col-md-3 mb-3">

                            <div class="border rounded-3 p-3 text-center">

                                <i class="bi bi-star-fill fs-2 text-warning"></i>

                                <h6 class="mt-2 mb-0">

                                    4.9

                                </h6>

                                <small class="text-muted">

                                    Rating

                                </small>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

            <!-- Instructor -->

            <div class="card shadow border-0">

                <div class="card-header bg-white">

                    <h4 class="mb-0">

                        Instructor

                    </h4>

                </div>

                <div class="card-body">

                    <div class="d-flex align-items-center">

                        <img src="~/Images/@Model.InstructorImage"
                             asp-append-version="true"
                             class="rounded-circle border"
                             width="110"
                             height="110"
                             style="object-fit:cover;" />

                        <div class="ms-4">

                            <h4 class="fw-bold mb-1">

                                @Model.InstructorName

                            </h4>

                            <p class="text-muted mb-0">

                                @Model.InstructorBio

                            </p>

                        </div>

                    </div>

                </div>

            </div>

        </div>

        <!-- ================= Sidebar ================= -->

        <div class="col-lg-4">

            <div class="card shadow-lg border-0 sticky-top"
                 style="top:100px;">

                <div class="card-header bg-success text-white">

                    <h4 class="mb-0">

                        Enrollment

                    </h4>

                </div>

                <div class="card-body">

                    <div class="mb-4">

                        <small class="text-muted">

                            Enrollment Date

                        </small>

                        <h6>

                            @Model.EnrollmentDate.ToString("dd MMM yyyy")

                        </h6>

                    </div>

                    <div class="mb-4">

                        <small class="text-muted">

                            Status

                        </small>

                        <br />

                        @if (Model.Status == CourseManagment.DAL.Enums.EnrollmentStatus.Active)
                        {
                            <span class="badge bg-success px-3 py-2">

                                Active

                            </span>
                        }
                        else if (Model.Status == CourseManagment.DAL.Enums.EnrollmentStatus.Completed)
                        {
                            <span class="badge bg-primary px-3 py-2">

                                Completed

                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger px-3 py-2">

                                Cancelled

                            </span>
                        }

                    </div>

                    <hr />

                    @if (Model.Status == CourseManagment.DAL.Enums.EnrollmentStatus.Active)
                    {
                        <a asp-action="MyLearning"
                           class="btn btn-primary w-100 mb-3">

                            <i class="bi bi-play-circle-fill me-2"></i>

                            Continue Learning

                        </a>

                        <form asp-action="Cancel"
                              method="post">

                            @Html.AntiForgeryToken()

                            <input type="hidden"
                                   name="id"
                                   value="@Model.EnrollmentId" />

                            <button class="btn btn-outline-danger w-100">

                                <i class="bi bi-x-circle me-2"></i>

                                Cancel Enrollment

                            </button>

                        </form>
                    }
                    else
                    {
                        <button class="btn btn-secondary w-100" disabled>

                            Enrollment Closed

                        </button>
                    }

                </div>

            </div>

        </div>

    </div>

</div>

<div class="footer">
    <div class="footer-container">
        <div class="footer-about">
            <div class="footer-logo">
                <img src="~/Images/finallooogggggooo.png" alt="">
                <h2>Learnio</h2>
            </div>

            <p><i class="fa-solid fa-phone"></i> +20 100 000 0000</p>

            <p><i class="fa-solid fa-envelope"></i> support@learnio.com</p>

            <p>
                <i class="fa-solid fa-location-dot"></i>
                Cairo, Egypt
            </p>
            <h3>We are on</h3>
            <div class="social-icons">
                <a href="#"><i class="fa-brands fa-facebook-f"></i></a>
                <a href="#"><i class="fa-brands fa-twitter"></i></a>
                <a href="#"><i class="fa-brands fa-instagram"></i></a>
                <a href="#"><i class="fa-brands fa-linkedin-in"></i></a>
            </div>

        </div>

        <div class="footer-links">
            <h3 class="footer-title">Company</h3>
            <ul>
                <li><a href="#">About Us</a></li>
                <li><a href="#">Contact Us</a></li>
                <li><a href="#">Become an Instructor</a></li>
                <li><a href="#">FAQs</a></li>
            </ul>

        </div>
        <div class="footer-links">
            <h3 class="footer-title">Courses</h3>
            <ul>
                <li><a href="#">Web Development</a></li>
                <li><a href="#">UI / UX</a></li>
                <li><a href="#">Data Science</a></li>
                <li><a href="#">Business</a></li>
                <li><a href="#">Artificial Intelligence</a></li>
            </ul>
        </div>

        <div class="footer-apps">
            <h3 class="footer-title">Download App</h3>
            <p>
                Download our mobile app and
                learn on the go.
            </p>
            <img src="~/Images/app store.png" alt="App Store">
            <img src="~/Images/goagle play.png" alt="Google Play">
        </div>

   
    
    </div>
    <hr>
    <div class="footer-bottom">
        <p>© 2026 Learnio. All Rights Reserved.</p>
        <div class="bottom-links">
            <a href="#">Terms & Conditions</a>
            <a href="#">Privacy Policy</a>
        </div>


    </div>
</div>

<style>
    .card {
        border-radius: 16px;
    }

    .card-img-top {
        border-radius: 16px 16px 0 0;
    }

    .card {
        transition: .3s;
    }

        .card:hover {
            transform: translateY(-4px);
        }

    .badge {
        font-size: .9rem;
    }

    .sticky-top {
        z-index: 10;
    }

    .border.rounded-3 {
        transition: .25s;
    }

        .border.rounded-3:hover {
            background: #f8f9fa;
            transform: translateY(-3px);
        }

    .card-header {
        border-bottom: none;
    }

    .btn {
        border-radius: 10px;
    }
</style>