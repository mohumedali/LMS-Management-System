@model CourseManagment.BLL.ViewModels.CategoriesVM.CreateCategoryViewModel

@{
    ViewData["Title"] = "Create Category";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">

    <div class="card shadow border-0">

        <div class="card-header bg-primary text-white">

            <h3 class="mb-0">
                <i class="fa-solid fa-folder-plus me-2"></i>
                Create New Category
            </h3>

        </div>

        <div class="card-body">

            <form asp-action="CreateCategory" method="post" enctype="multipart/form-data">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger"></div>

                <div class="mb-4">

                    <label asp-for="Name"
                           class="form-label fw-semibold"></label>

                    <input asp-for="Name"
                           class="form-control"
                           placeholder="Category Name" />

                    <span asp-validation-for="Name"
                          class="text-danger"></span>

                </div>

                <div class="col-md-6">

                    <label asp-for="Image"
                           class="form-label fw-semibold"></label>

                    <input asp-for="ImageFile"
                           type="file"
                           class="form-control"
                           accept="image/*" />

                    <span asp-validation-for="ImageFile"
                          class="text-danger"></span>

                </div>

                <div class="mb-4">

                    <label asp-for="Description"
                           class="form-label fw-semibold"></label>

                    <textarea asp-for="Description"
                              class="form-control"
                              rows="6"
                              placeholder="Category Description"></textarea>

                    <span asp-validation-for="Description"
                          class="text-danger"></span>

                </div>



                <div class="d-flex justify-content-end gap-2">

                    <a asp-action="CategoryManagement"
                       class="btn btn-secondary">

                        Cancel

                    </a>

                    <button type="submit"
                            class="btn btn-primary">

                        <i class="fa-solid fa-plus me-2"></i>

                        Create Category

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}