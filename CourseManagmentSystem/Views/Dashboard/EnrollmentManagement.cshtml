@using CourseManagment.DAL.Enums
@using CourseManagment.BLL.ViewModels.EnrollmentsVM
@model EnrollmentManagementPageViewModel

@{
    ViewData["Title"] = "Enrollment Management";
    Layout = "_AdminLayout";
}

<div class="container-fluid">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold mb-1">Enrollment Management</h2>
            <p class="text-muted mb-0">
                Manage all course enrollments
            </p>
        </div>

    </div>

    <!-- Statistics -->
    <div class="row g-3 mb-4">

        <div class="col-lg-3 col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body">

                    <h6 class="text-muted">
                        Total Enrollments
                    </h6>

                    <h2 class="fw-bold">
                        @Model.TotalEnrollments
                    </h2>

                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body">

                    <h6 class="text-success">
                        Active
                    </h6>

                    <h2 class="fw-bold text-success">
                        @Model.ActiveEnrollments
                    </h2>

                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body">

                    <h6 class="text-primary">
                        Completed
                    </h6>

                    <h2 class="fw-bold text-primary">
                        @Model.CompletedEnrollments
                    </h2>

                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-body">

                    <h6 class="text-danger">
                        Cancelled
                    </h6>

                    <h2 class="fw-bold text-danger">
                        @Model.CancelledEnrollments
                    </h2>

                </div>
            </div>
        </div>

    </div>

    <!-- Search -->

    <div class="card shadow-sm border-0 mb-4">

        <div class="card-body">

            <form method="get">

                <div class="row g-3">

                    <div class="col-md-8">

                        <input asp-for="Search"
                               class="form-control"
                               placeholder="Search by student or course..." />

                    </div>

                    <div class="col-md-3">

                        <select asp-for="Status"
                                class="form-select">

                            <option value="">All Status</option>

                            @foreach (var status in Enum.GetValues<EnrollmentStatus>())
                            {
                                <option value="@status">
                                    @status
                                </option>
                            }

                        </select>

                    </div>

                    <div class="col-md-1">

                        <button class="btn btn-dark w-100">

                            <i class="bi bi-search"></i>

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">

            @TempData["Success"]

        </div>
    }

    <!-- Table -->

    <div class="card shadow-sm border-0">

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>#</th>

                            <th>Student</th>

                            <th>Course</th>

                            <th>Instructor</th>

                            <th>Date</th>

                            <th>Status</th>

                            <th width="220">Actions</th>

                        </tr>

                    </thead>

                    <tbody>

                        @if (Model.Enrollments.Any())
                        {
                            @foreach (var item in Model.Enrollments)
                            {
                                <tr>

                                    <td>@item.Id</td>

                                    <td>

                                        @item.StudentName

                                    </td>

                                    <td>

                                        @item.CourseTitle

                                    </td>

                                    <td>

                                        @item.InstructorName

                                    </td>

                                    <td>

                                        @item.EnrollmentDate.ToString("dd MMM yyyy")

                                    </td>

                                    <td>

                                        @switch (item.Status)
                                        {
                                            case EnrollmentStatus.Active:

                                                <span class="badge bg-success">
                                                    Active
                                                </span>

                                                break;

                                            case EnrollmentStatus.Completed:

                                                <span class="badge bg-primary">
                                                    Completed
                                                </span>

                                                break;

                                            case EnrollmentStatus.Cancelled:

                                                <span class="badge bg-danger">
                                                    Cancelled
                                                </span>

                                                break;
                                        }

                                    </td>

                                    <td>

                                        <a asp-action="EnrollmentDetails"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-primary">

                                            <i class="bi bi-eye"></i>


                                        </a>

                                        <a asp-action="EditEnrollment"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-warning">

                                            <i class="bi bi-pencil-square"></i>



                                        </a>

                                    </td>

                                </tr>
                            }
                        }
                        else
                        {
                            <tr>

                                <td colspan="7"
                                    class="text-center py-5">

                                    <h5 class="text-muted">

                                        No enrollments found.

                                    </h5>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>