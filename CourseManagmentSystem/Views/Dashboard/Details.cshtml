@model CourseManagment.BLL.ViewModels.CoursesVM.CourseDetailsViewModel

@{
    ViewData["Title"] = "Course Details";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold">Course Details</h2>
            <p class="text-muted mb-0">
                View complete course information.
            </p>
        </div>

        <div>

            <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-warning me-2">

                <i class="bi bi-pencil-square"></i>
                Edit
            </a>

            <a asp-action="CourseManagment"
               class="btn btn-outline-secondary">

                <i class="bi bi-arrow-left"></i>
                Back
            </a>

        </div>

    </div>


    <div class="row">

        <!-- Left -->

        <div class="col-lg-4">

            <div class="card border-0 shadow-sm">

                <img src="~/Images/@Model.ImageUrl"
                     class="card-img-top"
                     style="height:250px;object-fit:cover;">

                <div class="card-body text-center">

                    <h4 class="fw-bold">

                        @Model.Title

                    </h4>

                    <span class="badge bg-success px-3 py-2">

                        @Model.Level

                    </span>

                    <hr />

                    <div class="row text-center">

                        <div class="col-6">

                            <h5 class="fw-bold text-success">

                                $@Model.Price

                            </h5>

                            <small class="text-muted">

                                Price

                            </small>

                        </div>

                        <div class="col-6">

                            <h5 class="fw-bold">

                                @Model.Duration h

                            </h5>

                            <small class="text-muted">

                                Duration

                            </small>

                        </div>

                    </div>

                </div>

            </div>

        </div>


        <!-- Right -->

        <div class="col-lg-8">

            <div class="card border-0 shadow-sm mb-4">

                <div class="card-header bg-white">

                    <h4 class="mb-0">

                        Course Information

                    </h4>

                </div>

                <div class="card-body">

                    <div class="row">

                        <div class="col-md-6 mb-4">

                            <label class="text-muted">

                                Category

                            </label>

                            <h6>

                                @Model.Category

                            </h6>

                        </div>

                        <div class="col-md-6 mb-4">

                            <label class="text-muted">

                                Language

                            </label>

                            <h6>

                                @Model.Language

                            </h6>

                        </div>

                        <div class="col-md-6 mb-4">

                            <label class="text-muted">

                                Instructor

                            </label>

                            <h6>

                                @Model.InstructorName

                            </h6>

                        </div>

                        <div class="col-md-6 mb-4">

                            <label class="text-muted">

                                Rating

                            </label>

                            <h6>

                                ⭐ @Model.AverageRating.ToString("0.0")

                            </h6>

                        </div>

                    </div>

                    <label class="text-muted">

                        Description

                    </label>

                    <p class="mt-2">

                        @Model.Description

                    </p>

                </div>

            </div>


            <!-- Instructor -->

            <div class="card border-0 shadow-sm mb-4">

                <div class="card-header bg-white">

                    <h4>

                        Instructor

                    </h4>

                </div>

                <div class="card-body d-flex align-items-center">

                    <img src="~/Images/@Model.InstructorImage"
                         class="rounded-circle me-4"
                         style="width:80px;height:80px;object-fit:cover;" />

                    <div>

                        <h5>

                            @Model.InstructorName

                        </h5>

                        <p class="text-muted mb-0">

                            @Model.InstructorBio

                        </p>

                    </div>

                </div>

            </div>


            <!-- Lessons -->

            <div class="card border-0 shadow-sm">

                <div class="card-header bg-white">

                    <h4>

                        Lessons

                    </h4>

                </div>

                <div class="card-body">

                    @if (Model.Lessons.Any())
                    {
                        <table class="table table-hover align-middle">

                            <thead>

                                <tr>

                                    <th>Title</th>

                                    <th>Duration</th>

                                </tr>

                            </thead>

                            <tbody>

                                @foreach (var lesson in Model.Lessons)
                                {
                                    <tr>

                                        <td>

                                            @lesson.Title

                                        </td>

                                        <td>

                                            @lesson.Duration min

                                        </td>

                                    </tr>
                                }

                            </tbody>

                        </table>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">

                            No lessons found.

                        </div>
                    }

                </div>

            </div>

        </div>

    </div>

</div>