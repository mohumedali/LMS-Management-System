@using CourseManagment.DAL.Enums
@using CourseManagment.BLL.ViewModels.EnrollmentsVM
@model EditEnrollmentViewModel

@{
    ViewData["Title"] = "Edit Enrollment";
    Layout = "_AdminLayout";
}

<div class="container">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-white">

                    <div class="d-flex justify-content-between align-items-center">

                        <h3 class="mb-0">
                            Edit Enrollment
                        </h3>

                        <a asp-action="EnrollmentManagement"
                           class="btn btn-outline-secondary">

                            <i class="bi bi-arrow-left"></i>

                            Back

                        </a>

                    </div>

                </div>

                <div class="card-body">

                    <form asp-action="EditEnrollment"
                          asp-route-id="@Model.Id"
                          method="post">

                        @Html.AntiForgeryToken()

                        <input asp-for="Id" type="hidden" />

                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger">
                        </div>

                        <!-- Status -->

                        <div class="mb-4">

                            <label asp-for="Status"
                                   class="form-label fw-semibold">
                            </label>

                            <select asp-for="Status"
                                    class="form-select">

                                @foreach (var status in Enum.GetValues<EnrollmentStatus>())
                                {
                                    <option value="@status">
                                        @status
                                    </option>
                                }

                            </select>

                            <span asp-validation-for="Status"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- Progress -->


                        <hr />

                        <div class="d-flex justify-content-end gap-2">

                            <a asp-action="EnrollmentManagement"
                               class="btn btn-outline-secondary">

                                Cancel

                            </a>

                            <button type="submit"
                                    class="btn btn-primary">

                                <i class="bi bi-check-circle"></i>

                                Save Changes

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}