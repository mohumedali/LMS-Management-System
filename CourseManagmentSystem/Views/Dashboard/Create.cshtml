@model CourseManagment.BLL.ViewModels.CoursesVM.CreateCourseViewModel

@{
    ViewData["Title"] = "Create Course";
    Layout = "_AdminLayout";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Create New Course</h2>
            <p class="text-muted mb-0">
                Add a new course to the platform.
            </p>
        </div>

        <a asp-controller="DashBoard" asp-action="CourseManagment" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i>
            Back
        </a>
    </div>

    <div class="card border-0 shadow-sm">

        <div class="card-body p-4">

            <form asp-action="Create" method="post" enctype="multipart/form-data">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger">
                </div>

                <div class="row g-4">

                    <div class="col-md-6">

                        <label asp-for="Title" class="form-label fw-semibold"></label>

                        <input asp-for="Title" class="form-control" />

                        <span asp-validation-for="Title"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6">

                        <label asp-for="Price" class="form-label fw-semibold"></label>

                        <input asp-for="Price"
                               class="form-control" />

                        <span asp-validation-for="Price"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6">

                        <label asp-for="Duration"
                               class="form-label fw-semibold"></label>

                        <input asp-for="Duration"
                               class="form-control" />

                        <span asp-validation-for="Duration"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6">

                        <label asp-for="Language"
                               class="form-label fw-semibold"></label>

                        <input asp-for="Language"
                               class="form-control" />

                        <span asp-validation-for="Language"
                              class="text-danger"></span>

                    </div>

                    <div class="col-md-6">

                        <label class="form-label fw-semibold">

                            Category

                        </label>

                        <select asp-for="CategoryId"
                                class="form-select">

                            <option value="">Select Category</option>

                            @foreach (var item in Model.Categories)
                            {
                                <option value="@item.Id">

                                    @item.Name

                                </option>
                            }

                        </select>

                    </div>

                    <div class="col-md-6">

                        <label class="form-label fw-semibold">

                            Instructor

                        </label>

                        <select asp-for="InstructorId"
                                class="form-select">

                            <option value="">Select Instructor</option>

                            @foreach (var item in Model.Instructors)
                            {
                                <option value="@item.Id">

                                    @item.Name

                                </option>
                            }

                        </select>

                    </div>

                    <div class="col-md-6">

                        <label class="form-label fw-semibold">

                            Level

                        </label>

                        <select asp-for="Level"
                                class="form-select">

                            @foreach (var level in Enum.GetValues<CourseManagment.DAL.Enums.CourseLevel>())
                            {
                                <option value="@level">

                                    @level

                                </option>
                            }

                        </select>

                    </div>

                    <div class="col-md-6">

                        <label asp-for="ImageUrl"
                               class="form-label fw-semibold"></label>

                        <input asp-for="ImageFile" type="file" class="form-control" />

                    </div>

                    <div class="col-12">

                        <label asp-for="Description"
                               class="form-label fw-semibold"></label>

                        <textarea asp-for="Description"
                                  rows="6"
                                  class="form-control">
                        </textarea>

                        <span asp-validation-for="Description"
                              class="text-danger"></span>

                    </div>

                </div>

                <hr class="my-4" />

                <div class="d-flex justify-content-end gap-2">

                    <a asp-action="CourseManagment"
                       class="btn btn-light">

                        Cancel

                    </a>

                    <button class="btn btn-success px-4">

                        <i class="bi bi-check-circle"></i>

                        Create Course

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>
<style>
    .form-control,
    .form-select {
        border-radius: 12px;
        min-height: 48px;
        border: 1px solid #dcdcdc;
    }

        .form-control:focus,
        .form-select:focus {
            border-color: #198754;
            box-shadow: 0 0 0 .15rem rgba(25,135,84,.15);
        }

    .card {
        border-radius: 18px;
    }

    textarea.form-control {
        min-height: 160px;
    }

    .btn {
        border-radius: 10px;
    }

    .form-label {
        margin-bottom: .5rem;
    }
</style>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}